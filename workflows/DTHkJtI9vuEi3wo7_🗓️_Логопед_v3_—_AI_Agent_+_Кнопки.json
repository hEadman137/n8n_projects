    {
      "parameters": {
        "jsCode": "const ctx = $input.first().json;\nconst data = ctx.text;\nconst freeByDate = ctx.freeByDate;\n\nlet action = null, date = null, time = null, replyText = null, replyMarkup = null;\n\nif (data.startsWith('date_')) {\n  date = data.slice(5);\n  const info = freeByDate[date];\n  const slots = info ? info.slots : [];\n  const label = info ? info.label : date;\n  action = 'show_times';\n  replyText = '\\uD83D\\uDCC5 *' + label + '* \\u2014 выберите время:';\n  const timeRows = slots.map(function(t) { return [{ text: '\\uD83D\\uDD50 ' + t, callback_data: 'time_' + date + '_' + t }]; });\n  timeRows.push([{ text: '\\u2B05\\uFE0F Другая дата', callback_data: 'back_dates' }]);\n  replyMarkup = { inline_keyboard: timeRows };\n} else if (data.startsWith('time_')) {\n  const parts = data.slice(5).split('_');\n  date = parts[0]; time = parts[1];\n  const label = freeByDate[date] ? freeByDate[date].label : date;\n  action = 'confirm';\n  replyText = 'Подтвердите запись:\\n\\n\\uD83D\\uDCC5 *' + label + ' в ' + time + '*\\n\\u23F1 60 минут';\n  replyMarkup = {\n    inline_keyboard: [\n      [{ text: '\\u2705 Записаться!', callback_data: 'confirm_' + date + '_' + time }],\n      [{ text: '\\u2B05\\uFE0F Другое время', callback_data: 'date_' + date }]\n    ]\n  };\n} else if (data.startsWith('confirm_')) {\n  const parts = data.slice(8).split('_');\n  date = parts[0]; time = parts[1];\n  action = 'book';\n} else if (data === 'back_dates') {\n  action = 'show_dates';\n  const freeDates = Object.keys(freeByDate);\n  replyText = 'Выберите удобную дату:';\n  replyMarkup = {\n    inline_keyboard: freeDates.map(function(d) {\n      const info = freeByDate[d];\n      const cnt = info.count;\n      const word = cnt === 1 ? 'слот' : (cnt < 5 ? 'слота' : 'слотов');\n      return [{ text: '\\uD83D\\uDCC5 ' + info.label + ' \\u2014 ' + cnt + ' ' + word, callback_data: 'date_' + d }];\n    })\n  };\n}\n\nreturn [{ json: Object.assign({}, ctx, { action: action, date: date, time: time, replyText: replyText, replyMarkup: replyMarkup }) }];\n"
      },
