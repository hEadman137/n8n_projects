    {
      "parameters": {
        "jsCode": "const inp = $('Разобрать входящее').first().json;\nconst chat_id = inp.chat_id;\nconst user_id = inp.user_id;\nconst text = inp.text;\nconst first_name = inp.first_name;\nconst isCallback = inp.isCallback;\nconst callback_id = inp.callback_id;\n\nconst busyEvents = $input.all().map(i => i.json);\nconst busySlots = busyEvents.map(e => ({\n  start: new Date(e.start?.dateTime || e.start?.date + 'T00:00:00+03:00'),\n  end:   new Date(e.end?.dateTime   || e.end?.date   + 'T23:59:59+03:00')\n})).filter(e => !isNaN(e.start.getTime()));\n\nconst WORK_START = 10, WORK_END = 17;\nconst freeByDate = {};\nconst now = new Date();\n\nfor (let offset = 1; offset <= 7; offset++) {\n  const day = new Date(now);\n  day.setDate(day.getDate() + offset);\n  const dow = day.getDay();\n  if (dow === 0) continue;\n\n  const dateStr = day.toISOString().slice(0,10);\n  const [y,m,dd] = dateStr.split('-');\n  const dayNames = ['Вс','Пн','Вт','Ср','Чт','Пт','Сб'];\n  const label = dayNames[dow] + ' ' + dd + '.' + m;\n\n  const slots = [];\n  for (let h = WORK_START; h < WORK_END; h++) {\n    const sStart = new Date(dateStr + 'T' + String(h).padStart(2,'0') + ':00:00+03:00');\n    const sEnd   = new Date(sStart.getTime() + 3600000);\n    const busy = busySlots.some(e => sStart < e.end && sEnd > e.start);\n    if (!busy) slots.push(String(h).padStart(2,'0') + ':00');\n  }\n  if (slots.length > 0) {\n    freeByDate[dateStr] = { label: label, slots: slots, count: slots.length };\n  }\n}\n\nconst slotsLines = Object.entries(freeByDate)\n  .map(function(e) { return e[1].label + ' (' + e[0] + '): ' + e[1].slots.join(', '); })\n  .join('\\n');\n\nreturn [{ json: {\n  chat_id: chat_id, user_id: user_id, text: text, first_name: first_name,\n  isCallback: isCallback, callback_id: callback_id,\n  freeByDate: freeByDate,\n  freeDates: Object.keys(freeByDate),\n  slotsText: slotsLines || 'Нет свободных слотов на ближайшую неделю',\n  isCallbackStr: isCallback ? 'yes' : 'no'\n}}];\n"
      },
