    {
      "parameters": {
        "jsCode": "\nconst msg = $input.first().json;\nconst isCallback = !!msg.callback_query;\nconst chat_id = String(isCallback\n  ? msg.callback_query.message.chat.id\n  : msg.message?.chat?.id || '');\nconst user_id = String(isCallback\n  ? msg.callback_query.from?.id\n  : msg.message?.from?.id || chat_id);\nconst text = isCallback\n  ? (msg.callback_query.data || '')\n  : (msg.message?.text || '');\nconst first_name = isCallback\n  ? (msg.callback_query.from?.first_name || '')\n  : (msg.message?.from?.first_name || '');\nconst callback_id = isCallback ? msg.callback_query.id : null;\nreturn [{ json: { chat_id, user_id, text, first_name, isCallback, callback_id } }];\n"
      },
