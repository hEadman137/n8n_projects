    {
      "id": "n-deepseek-direct",
      "name": "DeepSeek Direct",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        700
      ],
      "parameters": {
        "jsCode": "const ctx = $input.first().json;\nconst userId = ctx.user_id;\nconst userText = ctx.text;\nconst slotsText = ctx.slotsText || '';\nconst firstName = ctx.first_name || '';\nconst freeByDate = ctx.freeByDate || {};\nconst freeDates = Object.keys(freeByDate);\n\nfunction dateBtns() {\n  return freeDates.map(function(d) {\n    const info = freeByDate[d];\n    const cnt = info.count;\n    const word = cnt === 1 ? 'слот' : (cnt < 5 ? 'слота' : 'слотов');\n    return [{ text: '📅 ' + info.label + ' — ' + cnt + ' ' + word, callback_data: 'date_' + d }];\n  });\n}\n\n// /start — welcome + date buttons\nif (userText === '/start') {\n  const greet = firstName ? ('Hello' + firstName + '! 👋\\n\\n') : '';\n  const markup = freeDates.length > 0 ? { inline_keyboard: dateBtns() } : null;\n  return [{ json: Object.assign({}, ctx, {\n    output: greet + 'Я помогаю записаться к логопеду.\\n\\nВыберите удобную дату:',\n    replyMarkup: markup\n  })}];\n}\n\n// Conversation history\nconst sd = $getWorkflowStaticData('global');\nconst histKey = 'h_' + userId;\nlet history = sd[histKey] || [];\n\nconst systemMsg = 'Ты — Алиса, помощник по записи к логопеду. '\n  + 'Правила:\\n'\n  + '1. При первом сообщении — поздоровайся и предложи выбрать дату.\\n'\n  + '2. Когда хочет записаться — скажи \"выберите дату из кнопок ниже\".\\n'\n  + '3. Отвечай кратко (1-3 предложения), по-русски.\\n'\n  + '4. Не придумывай даты — только из [Свободных слотов].\\n'\n  + '5. Занятие 60 мин, отмена за 24ч.\\n\\n'\n  + '[Свободные слоты]:\\n' + slotsText;\n\nconst messages = [{ role: 'system', content: systemMsg }]\n  .concat(history.slice(-8))\n  .concat([{ role: 'user', content: userText }]);\n\nlet reply = '';\ntry {\n  const resp = await $helpers.httpRequest({\n    method: 'POST',\n    url: 'https://api.deepseek.com/chat/completions',\n    headers: {\n      'Authorization': 'Bearer sk-7f37cfdf82d54d60a3970e4f20e3622e',\n      'Content-Type': 'application/json'\n    },\n    body: { model: 'deepseek-chat', messages: messages, max_tokens: 500, temperature: 0.7 },\n    json: true\n  });\n  reply = resp.choices[0].message.content;\n  history = history.concat([\n    { role: 'user', content: userText },\n    { role: 'assistant', content: reply }\n  ]);\n  if (history.length > 20) history = history.slice(-20);\n  sd[histKey] = history;\n} catch(e) {\n  reply = 'Прошу прощения, сервис временно недоступен. Повторите запрос через минуту.';\n}\n\n// Show date buttons when booking intent detected\nconst wantsBook = /запис|слот|дату|выбер|хочу|когда|время|приём|доступн/i.test(userText + reply);\nconst replyMarkup = (wantsBook && freeDates.length > 0)\n  ? { inline_keyboard: dateBtns() }\n  : null;\n\nreturn [{ json: Object.assign({}, ctx, { output: reply, replyMarkup: replyMarkup }) }];\n"
      }
    }
  ],
