        "jsCode": "const input = $input.first().json;\nconst raw = input.choices?.[0]?.message?.content || '{}';\nlet parsed;\ntry {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = { message: 'Извините, произошла ошибка. Попробуйте ещё раз.', action: 'reply_only', booking: null, reschedule: null, cancel: null };\n}\n\nconst prev = $('Подготовить промпт').first().json;\n\nreturn [{ json: {\n  ...prev,\n  reply_message: parsed.message || 'Произошла ошибка, попробуйте снова.',\n  action: parsed.action || 'reply_only',\n  booking: parsed.booking || null,\n  reschedule: parsed.reschedule || null,\n  cancel: parsed.cancel || null,\n  fullResponse: parsed\n}}];"
      },
