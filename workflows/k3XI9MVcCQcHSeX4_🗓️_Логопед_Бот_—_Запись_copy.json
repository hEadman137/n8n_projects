      "parameters": {
        "jsCode": "const calEvent = $input.first().json;\nconst prev = $('Разобрать ответ DeepSeek').first().json;\n\n// Генерируем уникальный ID\nconst booking_id = 'B' + Date.now();\n\nreturn [{ json: {\n  ...prev,\n  calendar_event_id: calEvent.id || '',\n  booking_id,\n  rowToAppend: {\n    ID: booking_id,\n    Имя: prev.booking?.name || '',\n    Телефон: prev.booking?.phone || '',\n    Chat_ID: prev.chat_id,\n    Дата: prev.booking?.date || '',\n    Время: prev.booking?.time || '',\n    Статус: 'активна',\n    Calendar_Event_ID: calEvent.id || '',\n    Создано: new Date().toISOString()\n  }\n}}];"
