    {
      "parameters": {
        "jsCode": "// Собираем все входные данные\nconst msgData = $('Извлечь данные сообщения').first().json;\nconst chat_id = msgData.chat_id;\nconst userText = msgData.text;\nconst first_name = msgData.first_name;\n\n// Найти сессию для этого chat_id\nconst allSessions = $('Читать Сессии').all().map(i => i.json);\nconst session = allSessions.find(s => String(s.Chat_ID) === String(chat_id));\nconst history = session ? JSON.parse(session.История || '[]') : [];\nconst rowNumber = allSessions.findIndex(s => String(s.Chat_ID) === String(chat_id)) + 2; // +2 for header\n\n// Найти активные записи для этого chat_id\nconst allBookings = $('Читать Записи').all().map(i => i.json);\nconst myBookings = allBookings.filter(b => String(b.Chat_ID) === String(chat_id) && b.Статус === 'активна');\nconst bookingsText = myBookings.length > 0\n  ? myBookings.map(b => `- ${b.Дата} в ${b.Время} (ID: ${b.ID})`).join('\\n')\n  : 'нет активных записей';\n\n// Вычислить свободные слоты\nconst calData = $input.first().json;\nconst busyEvents = calData.calendarEvents || [];\nconst busySlots = busyEvents.map(e => ({\n  start: new Date(e.start?.dateTime || e.start?.date),\n  end: new Date(e.end?.dateTime || e.end?.date)\n})).filter(e => !isNaN(e.start));\n\nconst freeSlots = [];\nconst now = new Date();\nconst moscowOffset = 3 * 60; // UTC+3\nconst workStart = 9; // 9:00\nconst workEnd = 18; // 18:00\nconst slotDuration = 60; // minutes\n\nfor (let dayOffset = 0; dayOffset <= 13; dayOffset++) {\n  const day = new Date(now);\n  day.setDate(day.getDate() + dayOffset);\n  const dayOfWeek = day.getUTCDay(); // 0=Sun, 6=Sat\n  if (dayOfWeek === 0) continue; // Пропускаем воскресенье\n\n  const dateStr = day.toISOString().slice(0, 10);\n\n  for (let hour = workStart; hour < workEnd; hour++) {\n    const slotStart = new Date(`${dateStr}T${String(hour).padStart(2,'0')}:00:00+03:00`);\n    const slotEnd = new Date(slotStart.getTime() + slotDuration * 60000);\n\n    if (slotStart <= now) continue; // Не предлагаем прошедшее время\n\n    const isBusy = busySlots.some(e => slotStart < e.end && slotEnd > e.start);\n    if (!isBusy) {\n      const weekDays = ['Вс','Пн','Вт','Ср','Чт','Пт','Сб'];\n      freeSlots.push({\n        date: dateStr,\n        time: `${String(hour).padStart(2,'0')}:00`,\n        label: `${weekDays[dayOfWeek]} ${dateStr} в ${String(hour).padStart(2,'0')}:00`\n      });\n    }\n  }\n  if (freeSlots.length >= 20) break; // Показываем до 20 слотов\n}\n\nconst slotsText = freeSlots.slice(0, 15).map(s => s.label).join('\\n');\n\n// Текущая дата/время\nconst nowMoscow = new Date(Date.now() + moscowOffset * 60000);\nconst currentDateTime = nowMoscow.toISOString().replace('T', ' ').slice(0, 16) + ' (Москва)';\n\n// Собрать промпт для DeepSeek\nconst systemPrompt = `Ты — вежливый помощник по записи к логопеду. Тебя зовут Алиса.\nТекущая дата и время: ${currentDateTime}\n\nТвои задачи:\n1. Приветствовать клиента и выяснить его имя (если не знаешь)\n2. Помочь выбрать удобный слот из ДОСТУПНЫХ\n3. Подтвердить запись\n4. Помочь перенести или отменить запись\n\nДОСТУПНЫЕ СЛОТЫ (только из этого списка!):\n${slotsText || 'Нет свободных слотов на ближайшие 2 недели'}\n\nСУЩЕСТВУЮЩИЕ ЗАПИСИ КЛИЕНТА:\n${bookingsText}\n\nПравила:\n- Занятие длится 60 минут\n- Предлагай только из ДОСТУПНЫХ слотов выше\n- Собери имя клиента и выбранный слот для оформления записи\n- Для переноса: уточни старый слот и новый желаемый\n- Отвечай на русском, дружелюбно и коротко\n- Если хочешь перечислить слоты — перечисляй не более 5 самых ближайших\n\nОТВЕЧАЙ ТОЛЬКО ВАЛИДНЫМ JSON БЕЗ MARKDOWN:\n{\n  \"message\": \"текст ответа клиенту\",\n  \"action\": \"reply_only | book | reschedule | cancel\",\n  \"booking\": { \"name\": \"имя\", \"date\": \"YYYY-MM-DD\", \"time\": \"HH:MM\" },\n  \"reschedule\": { \"old_date\": \"YYYY-MM-DD\", \"old_time\": \"HH:MM\", \"new_date\": \"YYYY-MM-DD\", \"new_time\": \"HH:MM\" },\n  \"cancel\": { \"date\": \"YYYY-MM-DD\", \"time\": \"HH:MM\" }\n}\nПоля booking/reschedule/cancel — null если не применяется.`;\n\n// Добавляем текущее сообщение в историю\nconst updatedHistory = [...history, { role: 'user', content: userText }];\n// Ограничиваем историю последними 10 сообщениями\nconst trimmedHistory = updatedHistory.slice(-10);\n\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  ...trimmedHistory\n];\n\nreturn [{ json: {\n  chat_id,\n  first_name,\n  userText,\n  messages,\n  trimmedHistory,\n  freeSlots,\n  myBookings,\n  allBookings,\n  sessionRowNumber: session ? rowNumber : -1,\n  hasSession: !!session\n}}];"
      },
