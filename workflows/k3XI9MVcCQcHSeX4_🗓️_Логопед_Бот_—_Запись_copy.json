    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst allBookings = input.allBookings || [];\nconst c = input.cancel;\n\nconst booking = allBookings.find(b =>\n  String(b.Chat_ID) === String(input.chat_id) &&\n  b.Дата === c?.date &&\n  b.Время === c?.time &&\n  b.Статус === 'активна'\n);\n\nif (!booking) {\n  return [{ json: { ...input, error: 'booking_not_found', errorMsg: 'Запись не найдена.' } }];\n}\n\nreturn [{ json: { ...input, foundBooking: booking } }];"
      },
