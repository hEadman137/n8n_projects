      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst allBookings = input.allBookings || [];\nconst r = input.reschedule;\n\n// Ищем запись по дате и времени и chat_id\nconst booking = allBookings.find(b =>\n  String(b.Chat_ID) === String(input.chat_id) &&\n  b.Дата === r?.old_date &&\n  b.Время === r?.old_time &&\n  b.Статус === 'активна'\n);\n\nif (!booking) {\n  return [{ json: { ...input, error: 'booking_not_found', errorMsg: 'Запись не найдена. Проверьте дату и время.' } }];\n}\n\nreturn [{ json: { ...input, foundBooking: booking } }];"
      },
