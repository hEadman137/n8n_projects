    {
      "parameters": {
        "jsCode": "const input = $('Разобрать ответ DeepSeek').first().json;\nconst chat_id = input.chat_id;\nconst userText = input.userText;\nconst reply_message = input.reply_message;\nconst trimmedHistory = input.trimmedHistory || [];\nconst sessionRowNumber = input.sessionRowNumber;\nconst hasSession = input.hasSession;\n\n// Обновляем историю\nconst newHistory = [...trimmedHistory, { role: 'assistant', content: reply_message }].slice(-10);\n\nreturn [{ json: {\n  chat_id,\n  hasSession,\n  sessionRowNumber,\n  rowData: {\n    Chat_ID: chat_id,\n    История: JSON.stringify(newHistory),\n    Последнее_обновление: new Date().toISOString()\n  }\n}}];"
      },
