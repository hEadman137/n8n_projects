        "jsCode": "const msg = $input.first().json;\nconst chat_id = msg?.message?.chat?.id || msg?.callback_query?.message?.chat?.id || '';\nconst text = msg?.message?.text || msg?.callback_query?.data || '';\nconst first_name = msg?.message?.from?.first_name || msg?.callback_query?.from?.first_name || 'Клиент';\nconst username = msg?.message?.from?.username || '';\nreturn [{ json: { chat_id: String(chat_id), text: text.trim(), first_name, username, raw: msg } }];"
