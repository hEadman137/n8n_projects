      "name": "Пауза 1 сек (защита от бана)",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        1328,
        0
      ],
      "webhookId": "wait-webhook-id"
    },
    {
      "parameters": {
