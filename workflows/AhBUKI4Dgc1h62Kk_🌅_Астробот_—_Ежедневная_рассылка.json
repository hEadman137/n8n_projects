        "query": "INSERT INTO forecast_logs (telegram_id, sent_at, forecast_date)\nVALUES ({{ $('Разбить на элементы').item.json.telegram_id }}, NOW(), CURRENT_DATE)\nON CONFLICT DO NOTHING",
        "options": {}
