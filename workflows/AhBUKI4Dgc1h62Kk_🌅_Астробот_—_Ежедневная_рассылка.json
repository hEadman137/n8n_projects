    {
      "parameters": {
        "options": {}
      },
      "id": "b00661b2-7255-4556-a716-ed01c9dd04af",
      "name": "Разбить на элементы",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 2,
      "position": [
        448,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "gpt-4o-mini"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"Ты профессиональный астролог с многолетним опытом. Составляй персональные, уникальные и разнообразные астрологические прогнозы. Никогда не повторяй одинаковые тексты. Учитывай текущие астрологические события — фазы луны, ретроградные планеты, сезоны.\"}, {\"role\": \"user\", \"content\": \"Составь астрологический прогноз на сегодня для {{ $json.first_name }} {{ $json.last_name }}.\\n\\nЗнак зодиака: {{ $json.zodiac_sign }}\\nДата рождения: {{ $json.birthdate }}\\nСегодняшняя дата: {{ $now.toFormat('dd MMMM yyyy') }}\\n\\nФормат прогноза:\\n🔮 *Прогноз на {{ $now.toFormat('dd MMMM') }} для {{ $json.first_name }}*\\n\\n🌟 *Общий прогноз*\\n[2-3 предложения]\\n\\n💼 *Карьера и финансы*\\n[2 предложения]\\n\\n❤️ *Любовь и отношения*\\n[2 предложения]\\n\\n🏃 *Здоровье*\\n[1-2 предложения]\\n\\n✨ *Совет дня*\\n[1 вдохновляющее предложение]\\n\\nОбщий объём — 200-250 слов. Стиль — тёплый, личный, позитивный.\"}]"
            },
            {
              "name": "max_tokens",
              "value": 900
            },
            {
              "name": "temperature",
              "value": 0.9
            }
          ]
        },
        "options": {}
      },
      "id": "1b3c8234-a379-42db-8c22-60429e6b7d89",
      "name": "Генерировать персональный прогноз",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        672,
        -16
      ]
    },
    {
      "parameters": {
        "jsCode": "const forecastText = $('Генерировать персональный прогноз').item.json.choices[0].message.content;\nconst telegramId = $('Разбить на элементы').item.json.telegram_id;\n\nreturn [{ json: { telegram_id: telegramId, forecast: forecastText } }];"
      },
      "id": "d9f64930-358a-479d-970d-45353e84acd2",
      "name": "Подготовить сообщение",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        880,
        0
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $json.telegram_id }}",
        "text": "={{ $json.forecast }}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "fa2b9091-18b6-4301-92f6-5d1471ff0718",
      "name": "Отправить прогноз пользователю",
