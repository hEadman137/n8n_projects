      "name": "Get Channel Members",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Получаем данные из HTTP Request\nconst response = $input.first().json;\n\n// Получаем текущие переменные из Set ноды\nconst currentVars = $('Initialize Variables').first().json;\n\n// Проверяем структуру ответа\nif (!response || response.length === 0) {\n  console.log(\"edff\" + Array.isArray(response));\n  // Нет данных - останавливаем цикл\n  return [{\n    json: {\n      channel_id: currentVars.channel_id,\n      marker: null,\n      has_more_pages: false,\n      members: [],\n      total_loaded: currentVars.total_loaded,\n      page_number: currentVars.page_number\n    }\n  }];\n}\n\n// Извлекаем данные\nconst data = response;\nconst members = data.members || [];\nconst newMarker = data.marker;\n\n// Проверяем, есть ли еще страницы\n// Если marker === null или undefined, значит это последняя страница\nconst hasMorePages = newMarker !== null && newMarker !== undefined;\n\n// Подсчитываем общее количество загруженных\nconst totalLoaded = currentVars.total_loaded + members.length;\n\nconsole.log(`Page ${currentVars.page_number}: Loaded ${members.length} members, Total: ${totalLoaded}`);\nconsole.log(`Next marker: ${newMarker}, Has more: ${hasMorePages}`);\n\n// Возвращаем результат\nreturn [{\n  json: {\n    channel_id: currentVars.channel_id,\n    marker: newMarker,\n    has_more_pages: hasMorePages,\n    members: members,\n    total_loaded: totalLoaded,\n    page_number: currentVars.page_number\n  }\n}];"
      },
