    {
      "parameters": {
        "jsCode": "// Выводим ВСЁ что есть в input для диагностики\nconst inputData = $input.item.json;\nconst triggerData = $('Telegram Trigger').item.json;\n\n// Смотрим структуру trigger\nconst messageData = triggerData.message || null;\nconst callbackData = triggerData.callback_query || null;\n\nconst chatId = messageData?.chat?.id || callbackData?.message?.chat?.id || null;\nconst fromId = messageData?.from?.id || callbackData?.from?.id || null;\n\nconst status = inputData?.result?.status || '';\nconst validStatuses = ['member', 'administrator', 'creator'];\nconst isSubscribed = validStatuses.includes(status);\n\nreturn [{\n  json: {\n    is_subscribed: isSubscribed,\n    status,\n    chat_id: chatId,\n    user_id: fromId,\n    // Диагностика\n    _debug: {\n      has_message: !!messageData,\n      has_callback: !!callbackData,\n      raw_chat_id: messageData?.chat?.id,\n      raw_from_id: messageData?.from?.id,\n      api_response_ok: inputData?.ok,\n      api_error: inputData?.description || null\n    }\n  }\n}];"
      },
