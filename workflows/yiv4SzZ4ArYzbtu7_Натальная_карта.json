        "method": "POST",
        "url": "https://api.telegram.org/bot8018948513:AAGhjytjRj_XzU_I1wBbtJZ4HswMNOdYY9Q/sendMessage",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"chat_id\": {{ $('Парсим статус подписки').item.json.chat_id }},\n  \"text\": \"🌟 Для использования астрологического бота необходимо подписаться на наш канал.\\n\\nТам мы публикуем астрологические новости, общие прогнозы и полезные материалы ✨\\n\\nПодпишись и нажми кнопку «Проверить подписку» 👇\",\n  \"reply_markup\": {\n    \"inline_keyboard\": [\n      [\n        {\n          \"text\": \"⭐️ Подписаться на канал\",\n          \"url\": \"https://t.me/+efZLuuvf9zg0MzVi\"\n        }\n      ],\n      [\n        {\n          \"text\": \"✅ Проверить подписку\",\n          \"callback_data\": \"recheck_subscription\"\n        }\n      ]\n    ]\n  }\n}",
