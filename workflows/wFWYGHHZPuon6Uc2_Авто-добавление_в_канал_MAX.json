  "nodes": [
    {
      "parameters": {
        "content": "## 🔐 Авто-добавление в канал MAX\n\n**Как работает:**\n1. Пользователь пишет боту любое сообщение или нажимает кнопку\n2. Бот проверяет: уже участник канала?\n3. Если нет — добавляет через API и отправляет приветствие со ссылкой\n4. Если уже участник — сообщает об этом\n\n**Перед запуском:**\n- Убедитесь, что бот добавлен **администратором** канала с правом добавлять участников\n- Замените `CHANNEL_ID` в ноде «Инициализация» на ID вашего канала\n- Замените ссылку на канал в нодах с сообщениями",
        "height": 380,
        "width": 1200,
        "color": 4
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        0,
        0
      ],
      "id": "f2fcedc1-82dc-4269-9f9c-67ede8ed6e1d",
      "name": "Sticky Note"
    },
    {
      "parameters": {
        "additionalFields": {}
      },
      "type": "n8n-nodes-max.maxTrigger",
      "typeVersion": 1,
      "position": [
        240,
        400
      ],
      "id": "faff190f-602c-45d1-b330-de1f5b7dd7c8",
      "name": "Max Trigger",
      "webhookId": "86f17100-5e89-4a67-875e-0b0d0d34c088",
      "credentials": {
        "maxApi": {
          "id": "90hedW26kt6JLlax",
          "name": "Max account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const update = $input.item.json;\nconst updateType = update.update_type || '';\nconst isCallback = updateType === 'message_callback';\nconst isMessage  = updateType === 'message_created';\nconst isBotStart = updateType === 'bot_started';\n\nlet chatId, userId, firstName, username;\n\nconst fallbackChatId = update.message?.recipient?.chat_id || '';\n\nif (isCallback) {\n  const cb = update.callback;\n  userId    = cb.user?.user_id || '';\n  username  = cb.user?.username || '';\n  firstName = cb.user?.name || '';\n  chatId    = cb.message?.recipient?.chat_id || fallbackChatId;\n} else if (isMessage) {\n  const msg = update.message;\n  userId    = msg.sender?.user_id || '';\n  username  = msg.sender?.username || '';\n  firstName = msg.sender?.name || '';\n  chatId    = msg.recipient?.chat_id || fallbackChatId;\n} else if (isBotStart) {\n  userId    = update.user?.user_id || '';\n  username  = update.user?.username || '';\n  firstName = update.user?.name || '';\n  chatId    = update.chat_id || fallbackChatId;\n} else {\n  chatId = fallbackChatId;\n  userId = username = firstName = '';\n}\n\nreturn [{ json: { chatId, userId, username, firstName, updateType } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        400
      ],
      "id": "1d698c39-db16-4b37-9222-1dae8a74df96",
      "name": "Разбираем апдейт"
    },
    {
      "parameters": {
        "jsCode": "// Проверяем, является ли пользователь уже участником канала\nconst channelId = '-71330141790344';\nconst token = 'f9LHodD0cOKwdUROqAYYQEHJy9BDPFABPH9aym21zkZFQEOUn5FOixpjk9SjzMo3FMnF-Q52G86Jpz8M2x6r';\nconst userId = String($('Разбираем апдейт').item.json.userId);\n\nlet marker = null;\nlet isMember = false;\n\nfor (let page = 0; page < 50; page++) {\n  const url = `https://platform-api.max.ru/chats/${channelId}/members` +\n              (marker ? `?marker=${marker}` : '');\n\n  const res = await fetch(url, {\n    method: 'GET',\n    headers: { 'Authorization': token }\n  });\n\n  const body = await res.json();\n  const members = body.members || [];\n\n  if (members.some(m => String(m.user_id) === userId)) {\n    isMember = true;\n    break;\n  }\n\n  if (!body.marker) break;\n  marker = body.marker;\n}\n\nreturn [{ json: { ...$('Разбираем апдейт').item.json, is_member: isMember } }];"
      },
