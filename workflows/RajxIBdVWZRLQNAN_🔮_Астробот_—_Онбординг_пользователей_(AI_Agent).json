        "query": "WITH state_data AS (\n  SELECT temp_data FROM user_states WHERE telegram_id = {{ $('extract-state').item.json.telegram_id }}\n)\nINSERT INTO users (telegram_id, first_name, last_name, birthdate, zodiac_sign, is_active)\nSELECT\n  {{ $('extract-state').item.json.telegram_id }},\n  state_data.temp_data->>'first_name',\n  state_data.temp_data->>'last_name',\n  '{{ $('parse-birthdate').item.json.birthdate }}'::DATE,\n  '{{ $('parse-birthdate').item.json.zodiac }}',\n  true\nFROM state_data\nON CONFLICT (telegram_id) DO UPDATE SET\n  first_name = EXCLUDED.first_name,\n  last_name = EXCLUDED.last_name,\n  birthdate = EXCLUDED.birthdate,\n  zodiac_sign = EXCLUDED.zodiac_sign,\n  is_active = true;\n\nUPDATE user_states SET state = 'completed', updated_at = NOW() WHERE telegram_id = {{ $('extract-state').item.json.telegram_id }};",
