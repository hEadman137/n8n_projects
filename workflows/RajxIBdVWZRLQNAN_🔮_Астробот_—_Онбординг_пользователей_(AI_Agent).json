    {
      "parameters": {
        "chatId": "={{ $('extract-state').item.json.telegram_id }}",
        "text": "Приятно познакомиться, *{{ $('parse-name').item.json.first_name }}*! 🌟\n\nТеперь введи дату своего рождения в формате *ДД.ММ.ГГГГ*\n_Например: 15.03.1990_",
