      "parameters": {
        "jsCode": "const rows = $input.all();\nconst state = (rows[0] && rows[0].json && rows[0].json.state) ? rows[0].json.state : 'new';\nconst tempData = (rows[0] && rows[0].json && rows[0].json.temp_data) ? rows[0].json.temp_data : {};\nconst telegramId = $('Telegram Trigger').item.json.message.from.id;\nconst messageText = $('Telegram Trigger').item.json.message.text || '';\n\nreturn [{ json: { state, temp_data: tempData, telegram_id: telegramId, message_text: messageText } }];"
