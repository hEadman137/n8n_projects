          "name": "Natal Chart"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const text = $('extract-state').item.json.message_text.trim();\nconst parts = text.split(' ');\nconst firstName = parts[0] || '';\nconst lastName = parts.slice(1).join(' ') || '';\nreturn [{ json: { first_name: firstName, last_name: lastName } }];"
      },
