    {
      "parameters": {
        "jsCode": "// Парсим JSON-ответ агента\nconst raw = $input.first().json.output || '';\nlet parsed;\ntry {\n  // Убираем возможные markdown-обёртки\n  const clean = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(clean);\n} catch(e) {\n  // Если не смогли распарсить — возвращаем raw как USER_MESSAGE\n  parsed = {\n    USER_MESSAGE: raw,\n    ADMIN_MESSAGE: '',\n    SHEET_UPDATE: {},\n    NEXT_STAGE: $('Подготовка контекста').item.json.current_stage\n  };\n}\n\nreturn [{\n  json: {\n    USER_MESSAGE: parsed.USER_MESSAGE || '',\n    ADMIN_MESSAGE: parsed.ADMIN_MESSAGE || '',\n    SHEET_UPDATE: parsed.SHEET_UPDATE || {},\n    NEXT_STAGE: parsed.NEXT_STAGE || 'START',\n    // Прокидываем нужные поля для следующих нод\n    cuid: $('Подготовка контекста').item.json.cuid,\n    admin_chat_id: $('Подготовка контекста').item.json.admin_chat_id,\n    telegram_chat_id: $('Telegram Trigger').item.json.message.chat.id,\n    user_message_text: $('Edit Fields').item.json.text,\n    old_history: $('Подготовка контекста').item.json.history_of_messages\n  }\n}];"
