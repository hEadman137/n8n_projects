    {
      "parameters": {
        "jsCode": "// Получаем все результаты из Extract Tavily1\nconst tavilyData = $('Extract Tavily').first().json;\nconst allResults = tavilyData.results || [];\n\nconsole.log(`Total results from Tavily: ${allResults.length}`);\n\n// Получаем существующие URL из Google Sheets\n// (из предыдущего шага)\nconst sheetsData = $('Get row(s) in sheet').all();\nconst existingUrls = sheetsData.map(row => row.json.URL || row.json['Ссылки'] || row.json.url).filter(Boolean);\n\nconsole.log(`Existing URLs in sheet: ${existingUrls.length}`);\n\n// Фильтруем только новые URL\nconst newResults = allResults.filter(result => {\n  const url = result.url;\n  const isNew = !existingUrls.includes(url);\n  \n  if (!isNew) {\n    console.log('Skipping duplicate URL:', url);\n  }\n  \n  return isNew;\n});\n\nconsole.log(`New URLs found: ${newResults.length}`);\n\n// Если нет новых результатов - останавливаем workflow\nif (newResults.length === 0) {\n  throw new Error('No new articles found - all URLs already processed');\n}\n\n// Возвращаем новые результаты (они пойдут через Split Out)\nreturn [{ json: { results: newResults } }];"
      },
