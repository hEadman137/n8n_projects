    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// В режиме \"Run Once for Each Item\" данные приходят через $input\nconst item = $input.item.json;\n\nconsole.log('Input keys:', JSON.stringify(Object.keys(item)));\nconsole.log('Input data:', JSON.stringify(item).substring(0, 300));\n\nconst title = item.title || '';\nconst content = item.raw_content || item.content || '';\nconst url = item.url || '';\n\nlet imageUrl = null;\n\nlet html = '';\ntry {\n  html = $input.item.json.data || \n         $('Fetch Article HTML').first().json.data || '';\n} catch(e) {}\n\n// Парсим og:image\nconst ogPatterns = [\n  /<meta[^>]+property=[\"']og:image[\"'][^>]+content=[\"']([^\"']+)[\"']/i,\n  /<meta[^>]+content=[\"']([^\"']+)[\"'][^>]+property=[\"']og:image[\"']/i,\n  /<meta[^>]+name=[\"']twitter:image[\"'][^>]+content=[\"']([^\"']+)[\"']/i,\n];\n\nfor (const pattern of ogPatterns) {\n  const match = html.match(pattern);\n  if (match && match[1] && !match[1].includes('.svg')) {\n    imageUrl = match[1];\n    if (imageUrl.startsWith('/') && url) {\n      try { imageUrl = new URL(url).origin + imageUrl; } catch(e) {}\n    }\n    break;\n  }\n}\n\nif (!imageUrl && content) {\n  const imgMatch = content.match(/(https?:\\/\\/[^\\s\"'<>]+\\.(?:jpg|jpeg|png|webp))/i);\n  if (imgMatch) imageUrl = imgMatch[1];\n}\n\nreturn { title, content, url, imageUrl };"
      },
